      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "Total Active",
          "refId": "A"
        },
        {
          "expr": "pg_stat_activity_count{state=\"active\"}",
          "legendFormat": "Active Queries",
          "refId": "B"
        },
        {
          "expr": "pg_stat_activity_count{state=\"idle\"}",
          "legendFormat": "Idle",
          "refId": "C"
        },
        {
          "expr": "pg_setting_max_connections",
          "legendFormat": "Max Connections",
          "refId": "D"
        }
      ],
      "title": "Connection Statistics",
      "type": "timeseries"
    },
