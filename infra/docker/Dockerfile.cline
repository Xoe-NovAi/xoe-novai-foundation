# ============================================================================
# XNAi Cline CLI Service - Sovereign Authority (kat-coder-pro)
# ============================================================================
# Provides an isolated, high-reasoning execution environment for Cline.
# Benefits:
# - Isolation: Prevents host pollution and accidental destructive commands.
# - Tooling: Pre-baked technical toolchain (Node, Python, Git, etc.).
# - Resource Control: Governance via Docker/Podman limits.
# - Sovereignty: Direct access to local RAG filesystem and Knowledge Hub.
# ============================================================================

FROM node:20-slim

# Install system dependencies
RUN apt-get update && apt-get install -y 
    python3 
    python3-pip 
    git 
    curl 
    && rm -rf /var/lib/apt/apt/lists/*

# Install Cline CLI globally
RUN npm install -g @cline/cli

# Set up user
RUN useradd -m -u 1001 xnai_cline
USER xnai_cline
WORKDIR /workspace

# Configuration persistence
VOLUME ["/home/xnai_cline/.cline"]

# Knowledge access (Read-Only)
VOLUME ["/library", "/docs", "/expert-knowledge"]

# Default environment
ENV CLINE_MODEL="kwaipilot/kat-coder-pro"
ENV CLINE_API_PROVIDER="openrouter"

# Entrypoint for autonomous task execution
ENTRYPOINT ["cline"]
CMD ["--help"]
