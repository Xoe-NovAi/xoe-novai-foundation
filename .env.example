# ==========================================================================
# Xoe-NovAi Omega Stack v4.0 - Environment Configuration
# ==========================================================================

# --- PROJECT ROOTS (Hardened) ---
OMEGA_ROOT=.
DATA_ROOT=./data
MODELS_ROOT=./models
LIBRARY_ROOT=./library

# --- LLM INFERENCE ---
LLM_MODEL_PATH=${MODELS_ROOT}/Qwen3-0.6B-Q6_K.gguf
LLAMA_API_KEY=__REPLACE_WITH_SECRET__
LLAMA_CPP_N_THREADS=6
LLAMA_CPP_N_CTX=2048
LLAMA_CPP_N_BATCH=512
LLAMA_CPP_USE_MMAP=true
LLAMA_CPP_USE_MLOCK=true

# --- DATABASE CONFIG ---
POSTGRES_DB=vikunja
POSTGRES_USER=vikunja
POSTGRES_PASSWORD=vikunja123
POSTGRES_HOST=vikunja-db
POSTGRES_PORT=5432

# --- AGENT BUS ---
REDIS_HOST=redis
REDIS_PORT=6379
CONSUL_HOST=consul
CONSUL_PORT=8500

# --- PERFORMANCE ---
OPENBLAS_NUM_THREADS=6
N_THREADS=6

# --- OPENPIPE ---
OPENPIPE_API_KEY=your_openpipe_api_key_here
OPENPIPE_BASE_URL=http://openpipe:3000
OPENPIPE_CACHE_TTL=300
OPENPIPE_DEDUPLICATION_WINDOW=60
OPENPIPE_SOVEREIGN_MODE=true
