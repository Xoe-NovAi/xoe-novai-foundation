# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD: DO NOT HARDCODE. Enforced via ${REDIS_PASSWORD:?error} in compose.
REDIS_PASSWORD=YOUR_SECURE_PASSWORD_HERE

# Qdrant Configuration
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
VECTOR_SIZE=384

# Database Configuration
POSTGRES_PASSWORD=YOUR_DB_PASSWORD_HERE
VIKUNJA_DB_PASSWORD=YOUR_VIKUNJA_DB_PASSWORD_HERE

# Service Configuration
APP_UID=1000
APP_GID=1000

# Gemini API Configuration
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Persistence
INSTANCE_ROOT="/home/arcana-novai/Documents/Xoe-NovAi/omega-stack/storage/instances-active"
